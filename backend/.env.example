# ═══════════════════════════════════════════
#  ServiMatch Backend — Variables de entorno
#  Copia este archivo como .env y completa los valores
# ═══════════════════════════════════════════

# Base de datos PostgreSQL
# Railway te da esta URL automáticamente si usas su plugin de Postgres
DATABASE_URL="postgresql://user:password@localhost:5432/servimatch"

# JWT — genera strings aleatorios largos (mínimo 32 chars)
# En terminal: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="reemplaza_con_string_aleatorio_de_64_caracteres"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="otro_string_aleatorio_diferente_al_anterior"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis (Upstash en producción — gratis hasta 10k req/día)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# Servidor
PORT=3001
NODE_ENV="development"

# URL del frontend (para CORS)
FRONTEND_URL="http://localhost:3000"

# Supabase Storage — para imágenes (opcional en MVP)
# SUPABASE_URL="https://xxx.supabase.co"
# SUPABASE_SERVICE_KEY="your_service_key"
